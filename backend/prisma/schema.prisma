generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int            @id @default(autoincrement())
  email                 String         @unique
  password              String
  name                  String?
  profilePhoto          String?
  role                  String         @default("DIYER")
  repPoints             Int            @default(0)
  pushToken             String?
  phone                 String?
  location              String?
  businessHours         String?
  dailyDiagnoses        Int            @default(0)
  lastDiagnosisDate     DateTime?
  emailVerified         Boolean        @default(false)
  verificationToken     String?
  isAdmin               Boolean        @default(false)
  isVerified            Boolean        @default(false)
  isBanned              Boolean        @default(false)
  isAvailable           Boolean        @default(true)
  verificationRequest   String?
  resetToken            String?
  resetTokenExpiry      DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  logs                  Log[]
  vehicles              Vehicle[]
  posts                 Post[]
  comments              Comment[]
  likes                 Like[]
  followers             Follow[]       @relation("UserFollowing")
  following             Follow[]       @relation("UserFollowers")
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsGiven    Notification[] @relation("NotificationActor")
  blockedUsers          Block[]        @relation("Blocker")
  blockedBy             Block[]        @relation("Blocked")
  reports               Report[]       @relation("Reporter")
  jobsPosted            Job[]          @relation("JobPoster")
  bids                  Bid[]          @relation("BidMechanic")
  jobsClaimed           Job[]          @relation("JobMechanic")
  reviewsGiven          Review[]       @relation("ReviewGiver")
  reviewsReceived       Review[]       @relation("ReviewReceiver")
  parts                 Part[]
  carShows              CarShow[]
  carShowAttendees      CarShowAttendee[]
  messagesSent     Message[]        @relation("MessageSender")
messagesReceived Message[]        @relation("MessageReceiver")
conversations1   Conversation[]   @relation("ConversationUser1")
conversations2   Conversation[]   @relation("ConversationUser2")
}

model Post {
  id              Int       @id @default(autoincrement())
  userId          Int
  content         String
  imageUrl        String?
  imageUrls       String[]  @default([])
  postType        String    @default("VANITY")
  servicePrice    String?
  serviceLocation String?
  beforeImageUrl  String?
  afterImageUrl   String?
  pinned          Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])
  comments        Comment[]
  likes           Like[]
  reports         Report[]
}

model Comment {
  id        Int       @id @default(autoincrement())
  postId    Int
  userId    Int
  content   String
  parentId  Int?
  createdAt DateTime  @default(now())
  post      Post      @relation(fields: [postId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
}

model Like {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Vehicle {
  id               Int      @id @default(autoincrement())
  userId           Int
  year             Int
  make             String
  model            String
  trim             String?
  vin              String?
  engine           String?
  engineCylinders  String?
  displacement     String?
  driveType        String?
  color            String?
  mileage          Int?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  logs             Log[]
  user             User     @relation(fields: [userId], references: [id])
}

model Log {
  id          Int       @id @default(autoincrement())
  userId      Int
  vehicleId   Int
  title       String
  description String?
  mileage     Int?
  cost        Float?
  performedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    String?
  subcategory String?
  user        User      @relation(fields: [userId], references: [id])
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id])
  following   User     @relation("UserFollowing", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Notification {
  id          Int      @id @default(autoincrement())
  recipientId Int
  actorId     Int
  type        String
  postId      Int?
  jobId       Int?
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  recipient   User     @relation("NotificationRecipient", fields: [recipientId], references: [id])
  actor       User     @relation("NotificationActor", fields: [actorId], references: [id])
}

model Block {
  id          Int      @id @default(autoincrement())
  blockerId   Int
  blockedId   Int
  createdAt   DateTime @default(now())
  blocker     User     @relation("Blocker", fields: [blockerId], references: [id])
  blocked     User     @relation("Blocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
}

model Report {
  id         Int      @id @default(autoincrement())
  reporterId Int
  postId     Int?
  jobId      Int?
  reason     String
  createdAt  DateTime @default(now())
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id])
  post       Post?    @relation(fields: [postId], references: [id])
  job        Job?     @relation(fields: [jobId], references: [id])
}

model Job {
  id            Int      @id @default(autoincrement())
  userId        Int
  title         String
  description   String
  vehicle       String
  budget        Float?
  location      String?
  latitude      Float?
  longitude     Float?
  mechanicId    Int?
  status        String   @default("OPEN")
  acceptedBidId Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  poster        User     @relation("JobPoster", fields: [userId], references: [id])
  mechanic      User?    @relation("JobMechanic", fields: [mechanicId], references: [id])
  bids          Bid[]
  reviews        Review[]
  reports        Report[]
}

model Bid {
  id         Int      @id @default(autoincrement())
  jobId      Int
  mechanicId Int
  message    String
  price      Float
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  job        Job      @relation(fields: [jobId], references: [id])
  mechanic   User     @relation("BidMechanic", fields: [mechanicId], references: [id])

  @@unique([jobId, mechanicId])
}

model Review {
  id         Int      @id @default(autoincrement())
  jobId      Int
  reviewerId Int
  mechanicId Int
  rating     Int
  comment    String?
  reviewType String   @default("DIYER_TO_MECHANIC")
  createdAt  DateTime @default(now())
  job        Job      @relation(fields: [jobId], references: [id])
  reviewer   User     @relation("ReviewGiver", fields: [reviewerId], references: [id])
  mechanic   User     @relation("ReviewReceiver", fields: [mechanicId], references: [id])

  @@unique([jobId, reviewType])
}

model Part {
  id                Int      @id @default(autoincrement())
  userId            Int
  title             String
  description       String?
  category          String
  condition         String
  price             Float?
  priceType         String   @default("FIXED")
  imageUrl          String?
  status            String   @default("AVAILABLE")
  contactPreference String   @default("EMAIL")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

model CarShow {
  id          Int               @id @default(autoincrement())
  userId      Int
  name        String
  description String?
  location    String
  date        DateTime
  imageUrl    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id])
  attendees   CarShowAttendee[]
}

model CarShowAttendee {
  id        Int      @id @default(autoincrement())
  carShowId Int
  userId    Int
  createdAt DateTime @default(now())
  carShow   CarShow  @relation(fields: [carShowId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([carShowId, userId])
}

model playing_with_neon {
  id Int @id @default(autoincrement())

  @@ignore
}
model Conversation {
  id        Int       @id @default(autoincrement())
  user1Id   Int
  user2Id   Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user1     User      @relation("ConversationUser1", fields: [user1Id], references: [id])
  user2     User      @relation("ConversationUser2", fields: [user2Id], references: [id])
  messages  Message[]

  @@unique([user1Id, user2Id])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  senderId       Int
  receiverId     Int
  content        String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  receiver       User         @relation("MessageReceiver", fields: [receiverId], references: [id])
}
