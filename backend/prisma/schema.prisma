generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String? 
  role String @default("DIYER")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  logs      Log[]
  vehicles  Vehicle[]
}
model Vehicle {
  id        Int      @id @default(autoincrement())
  userId    Int
  year      Int
  make      String
  model     String
  trim      String?
  vin       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      Log[]
  user      User     @relation(fields: [userId], references: [id])
}

model Log {
  id          Int       @id @default(autoincrement())
  userId      Int
  vehicleId   Int
  title       String
  description String?
  mileage     Int?
  cost        Float?
  performedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    String?
  subcategory String?
  user        User      @relation(fields: [userId], references: [id])
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
}

model playing_with_neon {
  id Int @id @default(autoincrement())

  @@ignore
}
