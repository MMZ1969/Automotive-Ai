generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int            @id @default(autoincrement())
  email                 String         @unique
  password              String
  name                  String?
  profilePhoto          String?
  role                  String         @default("DIYER")
  repPoints             Int            @default(0)
  pushToken             String?
  phone                 String?
  dailyDiagnoses        Int           @default(0)
  lastDiagnosisDate     DateTime?
  isAdmin               Boolean       @default(false) 
  resetToken            String?
  resetTokenExpiry      DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  logs                  Log[]
  vehicles              Vehicle[]
  posts                 Post[]
  comments              Comment[]
  likes                 Like[]
  followers             Follow[]       @relation("UserFollowing")
  following             Follow[]       @relation("UserFollowers")
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsGiven    Notification[] @relation("NotificationActor")
  blockedUsers          Block[]        @relation("Blocker")
  blockedBy             Block[]        @relation("Blocked")
  reports               Report[]       @relation("Reporter")
  jobsPosted            Job[]          @relation("JobPoster")
  bids                  Bid[]          @relation("BidMechanic")
  reviewsGiven          Review[]       @relation("ReviewGiver")
  reviewsReceived       Review[]       @relation("ReviewReceiver")
  parts                 Part[]
}

model Post {
  id              Int       @id @default(autoincrement())
  userId          Int
  content         String
  imageUrl        String?
  postType        String    @default("VANITY")
  servicePrice    String?
  serviceLocation String?
  beforeImageUrl  String?
  afterImageUrl   String?
  pinned          Boolean   @default(false)   // 👈 ADD THIS
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])
  comments        Comment[]
  likes           Like[]
  reports         Report[]
}

model Comment {
  id        Int       @id @default(autoincrement())
  postId    Int
  userId    Int
  content   String
  parentId  Int?
  createdAt DateTime  @default(now())
  post      Post      @relation(fields: [postId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
}

model Like {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Vehicle {
  id        Int      @id @default(autoincrement())
  userId    Int
  year      Int
  make      String
  model     String
  trim      String?
  vin       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      Log[]
  user      User     @relation(fields: [userId], references: [id])
}

model Log {
  id          Int       @id @default(autoincrement())
  userId      Int
  vehicleId   Int
  title       String
  description String?
  mileage     Int?
  cost        Float?
  performedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    String?
  subcategory String?
  user        User      @relation(fields: [userId], references: [id])
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id])
  following   User     @relation("UserFollowing", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Notification {
  id          Int      @id @default(autoincrement())
  recipientId Int
  actorId     Int
  type        String
  postId      Int?
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  recipient   User     @relation("NotificationRecipient", fields: [recipientId], references: [id])
  actor       User     @relation("NotificationActor", fields: [actorId], references: [id])
}

model Block {
  id          Int      @id @default(autoincrement())
  blockerId   Int
  blockedId   Int
  createdAt   DateTime @default(now())
  blocker     User     @relation("Blocker", fields: [blockerId], references: [id])
  blocked     User     @relation("Blocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
}

model Report {
  id         Int      @id @default(autoincrement())
  reporterId Int
  postId     Int
  reason     String
  createdAt  DateTime @default(now())
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id])
  post       Post     @relation(fields: [postId], references: [id])

  @@unique([reporterId, postId])
}

model Job {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  description String
  vehicle     String
  budget      Float?
  location    String?
  status      String   @default("OPEN")
  acceptedBidId Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  poster      User     @relation("JobPoster", fields: [userId], references: [id])
  bids        Bid[]
  review      Review?
}

model Bid {
  id         Int      @id @default(autoincrement())
  jobId      Int
  mechanicId Int
  message    String
  price      Float
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  job        Job      @relation(fields: [jobId], references: [id])
  mechanic   User     @relation("BidMechanic", fields: [mechanicId], references: [id])

  @@unique([jobId, mechanicId])
}

model Review {
  id         Int      @id @default(autoincrement())
  jobId      Int      @unique
  reviewerId Int
  mechanicId Int
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  job        Job      @relation(fields: [jobId], references: [id])
  reviewer   User     @relation("ReviewGiver", fields: [reviewerId], references: [id])
  mechanic   User     @relation("ReviewReceiver", fields: [mechanicId], references: [id])
}

model Part {
  id                Int      @id @default(autoincrement())
  userId            Int
  title             String
  description       String?
  category          String
  condition         String
  price             Float?
  priceType         String   @default("FIXED")
  imageUrl          String?
  status            String   @default("AVAILABLE")
  contactPreference String   @default("EMAIL")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

model playing_with_neon {
  id Int @id @default(autoincrement())

  @@ignore
}